Script "BossMapCheck" (VOID)
{
	If( StrCmp(StrParam(n:PRINTNAME_LEVEL), "E1M8") == 0 )
	{
		//delay(delaytic);
		ACS_NamedExecute("BruiserHealth", 0, 0, 0, 0);
	}
	If( StrCmp(StrParam(n:PRINTNAME_LEVEL), "E2M8") == 0 )
	{
		//delay(delaytic);
		ACS_NamedExecute("BossHealth", 0, 0, 0, 0);
	}
	If( StrCmp(StrParam(n:PRINTNAME_LEVEL), "E3M8") == 0 )
	{
		//delay(delaytic);
		ACS_NamedExecute("BossHealth", 0, 0, 0, 0);
	}
	If( (StrCmp(StrParam(n:PRINTNAME_LEVEL), "MAP30") == 0 || StrCmp(StrParam(n:PRINTNAME_LEVEL), "TN_MAP30") == 0 || StrCmp(StrParam(n:PRINTNAME_LEVEL), "PL_MAP30") == 0) )
	{
		//delay(delaytic);
		ACS_NamedExecute("BossHealth", 0, 0, 0, 0);
	}
}

int BTID; //Boss ThingID
int BROA; //Boss ThingID
int BROB; //Boss ThingID

script "MakeMeBad" (VOID)
{
	BTID = UniqueTID();
	Thing_ChangeTID(0, BTID);
	int	bosshealth = FixedMul(GetActorProperty(BTID, APROP_Health), 3.0);
	int	bossmaxhealth = FixedMul(GetActorProperty(BTID, APROP_SpawnHealth), 3.0);
	delay(5);
	SetActorProperty(BTID, APROP_HEALTH, BossMaxHealth);
	SetActorProperty(BTID, APROP_SPAWNHEALTH, BossMaxHealth);
	SetActorFlag(BTID, "MISSILEMORE", 1);
	SetActorFlag(BTID, "ALWAYSFAST", 1);
	SetActorFlag(BTID, "BOSSDEATH", 1);
	//ACS_NamedExecute("BossHealth", 0, 0, 0, 0);
}

script "BruiserBroA" (VOID)
{
	BROA = UniqueTID();
	Thing_ChangeTID(0, BROA);
	//int	bosshealth = GetActorProperty(BROA, APROP_Health);
	//int	bossmaxhealth = bosshealth + GetActorProperty(BROA, APROP_SpawnHealth);
	if ( checkinventory("BelpheBro") == 1 )
	terminate;
	int	bosshealth = FixedMul(GetActorProperty(BROA, APROP_Health), 3.0);
	int	bossmaxhealth = FixedMul(GetActorProperty(BROA, APROP_SpawnHealth), 3.0);
	delay(5);
	SetActorProperty(BROA, APROP_SPAWNHEALTH, BossMaxHealth);
	SetActorProperty(BROA, APROP_HEALTH, BossMaxHealth);
	SetActorFlag(BROA, "MISSILEMORE", 1);
	SetActorFlag(BROA, "ALWAYSFAST", 1);
	SetActorFlag(BROA, "BOSSDEATH", 1);
	//ACS_NamedExecute("BruiserHealth", 0, 0, 0, 0);
}

script "BruiserBroB" (VOID)
{
	BROB = UniqueTID();
	Thing_ChangeTID(0, BROB);
	//int	bosshealth = GetActorProperty(BROB, APROP_Health);
	//int	bossmaxhealth = bosshealth + GetActorProperty(BROB, APROP_SpawnHealth);
