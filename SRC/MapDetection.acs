script "MakeMeBitch" (VOID)
{
	Int BITCH = UniqueTID();
	Thing_ChangeTID(0, BITCH);
	SetActorFlag(BITCH, "COUNTKILL", 0);
	SetActorFlag(BITCH, "THRUACTORS", 1);
	SetActorFlag(BITCH, "NOTARGET", 1);
	SetActorFlag(BITCH, "NOBLOCKMAP", 1);
	Delay(35);
	Thing_Remove(BITCH);
}

Script "SetBossMode" (VOID) NET
{
	if((!GetCVAR("sv_allowbossmap")) && ((PlayerNumber() == -1) || !IsNetworkGame()))
	{
		SetCvar("sv_allowbossmap", 1);
		//ChangeLevel(StrParam(n:PRINTNAME_LEVEL),0,CHANGELEVEL_NOINTERMISSION,StrParam(n:PRINTNAME_SKILL));
		ChangeLevel(StrParam(n:PRINTNAME_LEVEL),0,CHANGELEVEL_NOINTERMISSION,-1);
	}
	Else
	SetCvar("sv_allowbossmap", 0);
	//ChangeLevel(StrParam(n:PRINTNAME_LEVEL),0,CHANGELEVEL_NOINTERMISSION,StrParam(n:PRINTNAME_SKILL));
	ChangeLevel(StrParam(n:PRINTNAME_LEVEL),0,CHANGELEVEL_NOINTERMISSION,-1);
}

function int LiquidReplacement(void)
{
	int LTP;
	if ( GetCvar("LTP_Largesplash") || GetCvar("LTP_Smallsplash") || GetCvar("LTP_Largesplashsize") )
	{ LTP = 1; }
	else
	{ LTP = 0; }
	return LTP;
}

Script "ReplaceLiquids" ENTER
{
	ReplaceTextures("LAVAFL", "LAVA1");
	delay(35);
	if ( LiquidReplacement() )
	{ ReplaceTextures("LFALL01", "LPLAVAF"); }
	
	delay(1);
}

// God says he's away.