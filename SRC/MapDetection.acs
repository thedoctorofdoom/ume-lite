	SetActorProperty(BROB, APROP_HEALTH, BossMaxHealth);
	SetActorFlag(BROB, "MISSILEMORE", 1);
	SetActorFlag(BROB, "ALWAYSFAST", 1);
	SetActorFlag(BROB, "BOSSDEATH", 1);
	//ACS_NamedExecute("BruiserHealthB", 0, 0, 0, 0);
}

script "BossHealth" (void)
{
	int	bosshealth;
	int	bossmaxhealth;
	//BTID = ActivatorTID();
	if(BTID == 0)
	{
		BTID = UniqueTID();
		Thing_ChangeTID(0, BTID);
	}

    //Let's write the Boss's name here.
	setfont("BIGFONT");
	HudMessageBold(s:"-= BOSS =-"; HUDMSG_PLAIN, 0, CR_RED, 1.5, 0.09, 0.1, 1.0);
	
	
	//How much health the boss currently has.
	setfont("SMALLFONT");
	bosshealth = GetActorProperty(BTID, APROP_Health);
	HudMessageBold(d:bosshealth; HUDMSG_PLAIN, 0, CR_WHITE, 1.43, 0.15, 0.1, 1.0);
	
	//Just a divider
	HudMessageBold(s:"/"; HUDMSG_PLAIN, 0, CR_WHITE, 1.5, 0.15, 0.05, 1.0);
	
	
	//The boss's max health.
	if ( checkactorinventory(BTID, "IsGateKeeper") == 1 )
	{
		bossmaxhealth = GetActorProperty(BTID, APROP_SpawnHealth);
	}
	else
	{
		bossmaxhealth = FixedMul(GetActorProperty(BTID, APROP_SpawnHealth), 3.0);
	}
	HudMessageBold(d:bossmaxhealth; HUDMSG_PLAIN, 0, CR_WHITE, 1.57, 0.15, 0.1, 1.0);
	delay(1);
	
	
	//Check if the boss still is alive. If yes, repeat the script, if not, it ends here.
	if (GetActorProperty(BTID, APROP_Health)> 1)
	restart;
	else
    ;

}

// The Bruiser Brothers

script "BruiserHealth" (void)
{
	int	bosshealth1;
	int	bosshealth2;
	int	bossmaxhealth1;
	int	bossmaxhealth2;

    //Let's write the Boss's name here.
	setfont("BIGFONT");
	HudMessageBold(s:"-= BOSS =-"; HUDMSG_PLAIN, 0, CR_RED, 0.5, 0.09, 0.1, 1.0);
	
	
	//How much health the boss currently has.
	setfont("SMALLFONT");
	bosshealth1 = GetActorProperty(BROA, APROP_Health);
	bosshealth2 = GetActorProperty(BROB, APROP_Health);
	
	HudMessageBold(d:bosshealth1; HUDMSG_PLAIN, 0, CR_WHITE, 1.23, 0.15, 0.1, 1.0);
	HudMessageBold(d:bosshealth2; HUDMSG_PLAIN, 0, CR_WHITE, 1.63, 0.15, 0.1, 1.0);
	
	
	//Just a divider
	HudMessageBold(s:"/"; HUDMSG_PLAIN, 0, CR_WHITE, 1.3, 0.15, 0.05, 1.0);
	HudMessageBold(s:"/"; HUDMSG_PLAIN, 0, CR_WHITE, 1.7, 0.15, 0.05, 1.0);
	
	//The boss's max health.
	if ( checkactorinventory(BROA, "BelpheBro") == 1 || checkactorinventory(BROB, "BelpheBro") == 1 )
	{
		bossmaxhealth1 = GetActorProperty(BROA, APROP_SpawnHealth);
		bossmaxhealth2 = GetActorProperty(BROA, APROP_SpawnHealth);
	}
	else
	{
		bossmaxhealth1 = FixedMul(GetActorProperty(BROA, APROP_SpawnHealth), 3.0);
		bossmaxhealth2 = FixedMul(GetActorProperty(BROA, APROP_SpawnHealth), 3.0);
	}
	HudMessageBold(d:bossmaxhealth1; HUDMSG_PLAIN, 0, CR_WHITE, 1.37, 0.15, 0.1, 1.0);
	HudMessageBold(d:bossmaxhealth2; HUDMSG_PLAIN, 0, CR_WHITE, 1.77, 0.15, 0.1, 1.0);
	delay(1);
	
	
	//Check if the boss still is alive. If yes, repeat the script, if not, it ends here.
	if (GetActorProperty(BROA, APROP_Health)> 1)
	restart;
	
	if (GetActorProperty(BROB, APROP_Health)> 1)
	restart;
	
	Floor_LowerToLowest (666, 20);

}

